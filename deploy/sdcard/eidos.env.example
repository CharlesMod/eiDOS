# eiDOS — Per-deployment configuration
# Copy this file to eidos.env and fill in your values before running prepare_sdcard.sh

# Tailscale auth key (reusable, from https://login.tailscale.com/admin/settings/keys)
# Create a reusable key; non-expiring recommended for fleet use.
TAILSCALE_AUTHKEY=tskey-auth-CHANGEME

# GGUF model download URL (direct link, not blob URL)
MODEL_URL=https://huggingface.co/HauhauCS/Qwen3.5-4B-Uncensored-HauhauCS-Aggressive/resolve/main/Qwen3.5-4B-Uncensored-HauhauCS-Aggressive-Q4_K_M.gguf

# Pi username (must match what you set in Raspberry Pi Imager)
PI_USER=pi
