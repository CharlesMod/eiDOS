[Unit]
Description=eiDOS autonomous LLM agent
After=network.target llama-server.service
Wants=llama-server.service

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/eidos
ExecStart=/usr/bin/python3 eidos.py --config config.toml
Restart=always
RestartSec=30
RuntimeMaxSec=86400
Environment=PYTHONUNBUFFERED=1

# Resource limits
MemoryMax=3G
CPUQuota=80%

[Install]
WantedBy=multi-user.target
