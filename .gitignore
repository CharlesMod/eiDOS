deploy/sdcard/eidos.env

# --- eiDOS repo hygiene ---
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.tmp

# Runtime workspace state (the mind's memory/logs; recreated at runtime)
workspace/*
!workspace/goal.md
workspace.pi-backup/

# stray TTS test artifacts (repo root)
say.wav
speak_output.wav
tts_output_*.mp3

# self-authored-skill output that lands in the repo root (should live in workspace/)
boss_habits.log
# stray probe/snapshot artifacts a skill dumped into the repo root (HTML/JSON saved by
# http_request / camera-snapshot skills; e.g. a `>null` redirect or snapshot_*.jpg)
/null
/snapshot_*.jpg

# machine-local seed nuggets (device credentials/keys) — NEVER commit
preserved_nuggets.local.toml

# embedding model (90MB ONNX + tokenizer) — fetch with `python setup_embedding.py`, never commit
models/
